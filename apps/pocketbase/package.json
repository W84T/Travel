{
  "name": "pocketbase-app",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "./pocketbase serve --http=0.0.0.0:8090 --hooksWatch=false",
    "start": "./pocketbase serve --http=0.0.0.0:8090 --dir=/data --migrationsDir=./pb_migrations --hooksDir=./pb_hooks --hooksWatch=false",
    "migrations:up": "./pocketbase migrate up --dir=./pb_data --migrationsDir=./pb_migrations",
    "migrations:revert": "./pocketbase migrate down --dir=./pb_data --migrationsDir=./pb_migrations",
    "migrations:snapshot": "mkdir -p ./pb_snapshots && ./pocketbase migrate collections --dir=./pb_data --migrationsDir=./pb_snapshots",
    "update": "./pocketbase update"
  }
}